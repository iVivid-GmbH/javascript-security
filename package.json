{
  "name": "javascript-security-reference",
  "version": "1.0.0",
  "description": "Complete JavaScript & Frontend Security Reference — Reveal.js 2D presentation + Slidev + 45 deep-dive markdown files",
  "private": true,
  "scripts": {
    "present": "npx serve . --listen 8080 --no-clipboard",
    "dev": "slidev slides.md --open",
    "build": "slidev build slides.md --base /javascript-security/",
    "export:slidev-pdf": "slidev export slides.md --format pdf --output dist/js-security-slidev.pdf",
    "export:reveal-pdf": "node scripts/export-reveal-pdf.js",
    "preview": "npx serve dist"
  },
  "dependencies": {
    "@slidev/cli": "^0.49.0",
    "@slidev/theme-default": "^0.25.0"
  },
  "devDependencies": {
    "playwright": "^1.50.0"
  }
}
